# 复制为 .env 后由 docker compose 自动加载（可选）
# cp .env.example .env

# 映射到容器的 80 端口，默认 18080
HOST_PORT=18080

# 服务端 /api 与媒体上传鉴权（可选）
# - 留空：/api 对同容器 nginx 放行（Node 仅监听 127.0.0.1，不直接对外）；
#   前端自动切入"服务端存储"模式，数据保存在 ./data/sakura-nav/sakura.db
# - 填写：nginx 会自动注入 Authorization: Bearer，浏览器不带密钥；外部直连 /api 需带此 Bearer
# SAKURA_API_KEY=your-secret-key

# 图床的公开 URL 前缀（可选 · 借鉴 grok2api 的 app.app_url）
# - 留空：图库返回相对路径（/api/gallery/image/xxx.png），浏览器自动拼成当前 nav 域
# - 填写：返回绝对 URL，复制出来的链接走这个域；适合 nav 主站 + 独立 CDN 域的分离部署
#   例：APP_URL=https://cdn.xianran.de
# 改后只对【之后】上传的图生效；老图的 URL 仍存在 IDB 里走旧域，刷一下图库或重新上传可更新
# APP_URL=
