# 复制为 .env 后由 docker compose 自动加载（可选）
# cp .env.example .env

# 映射到容器的 80 端口，默认 18080
HOST_PORT=18080

# 宿主机上的持久化数据目录。这里会保存 SQLite、上传背景、音乐和歌词。
# 默认 ./data 已被 .gitignore 忽略，不会随代码上传。
SAKURA_DATA_HOST_DIR=./data

# 容器内应用实际写入的目录。请保持在 /data 下，才能被上面的宿主目录持久化。
SAKURA_DATA_DIR=/data/sakura-nav

# 服务端 /api 与媒体上传鉴权（可选）
# - 留空：/api 对同容器 nginx 放行（Node 仅监听 127.0.0.1，不直接对外）；
#   前端自动切入"服务端存储"模式，数据默认保存在 ./data/sakura-nav/sakura.db
# - 填写：nginx 会自动注入 Authorization: Bearer，浏览器不带密钥；外部直连 /api 需带此 Bearer
# SAKURA_API_KEY=your-secret-key
